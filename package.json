{
  "name": "sumopod-pay",
  "version": "0.1.0",
  "description": "Unofficial SDK for SumoPod Payment Gateway — works with Node.js, Bun, Express, and NestJS",
  "author": "Muhammad Fadhila Abiyyu Faris <fadhila36@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/fadhila36/sumopod-pay.git"
  },
  "bugs": {
    "url": "https://github.com/fadhila36/sumopod-pay/issues"
  },
  "homepage": "https://github.com/fadhila36/sumopod-pay#readme",
  "license": "MIT",
  "keywords": [
    "sumopod",
    "payment-gateway",
    "qris",
    "indonesia",
    "nestjs",
    "express",
    "bun",
    "nodejs",
    "sdk",
    "payment"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.mjs",
      "require": "./dist/nest.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bun": "bun test",
    "lint": "eslint src/ test/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "express": "^4.18.0 || ^5.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.0.0",
    "express": "^4.21.0",
    "msw": "^2.7.0",
    "prettier": "^3.5.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "supertest": "^7.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
