# SumoPod Pay SDK environment variables
# Copy this file to .env and fill in your values

# Your SumoPod API key (from the dashboard)
SUMOPOD_API_KEY=your_api_key_here

# Base URL for the SumoPod API
SUMOPOD_BASE_URL=https://api-pay-sandbox.sumopod.com/api/v1

# Webhook verification — Svix-style signature secret
SUMOPOD_WEBHOOK_SECRET=whsec_xxx

# Webhook verification — simple token
SUMOPOD_WEBHOOK_TOKEN=whtok_xxx
